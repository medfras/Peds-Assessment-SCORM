# Local FTO feedback report database connection.
#
# Copy this file to .env.fto-report and paste Render's External Database URL.
# Do not use the Render Internal Database URL from your Mac; it only resolves
# from Render services.
#
# Either form works:
# REPORT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# REPORT_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME

REPORT_DATABASE_URL=

# Alternative component form, useful if you do not want one long URL:
# REPORT_DB_HOST=
# REPORT_DB_PORT=5432
# REPORT_DB_NAME=
# REPORT_DB_USER=
# REPORT_DB_PASSWORD=
# REPORT_DB_SSLMODE=require
