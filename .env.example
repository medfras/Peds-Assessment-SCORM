# Groq API Key (free at https://console.groq.com — no credit card required)
GROQ_API_KEY=your_groq_api_key_here

# Environment — controls production guards (secret validation, docs disable, etc.)
# Must be set explicitly in every deployment. Values: development | staging | production
ENV=development

# ── Deterministic corroboration (SCORE-01) ───────────────────────────────────
# shadow mode: runs deterministic check alongside LLM prepass and logs
# ai.corroboration.shadow_comparison events — observe-only, does not affect scoring.
# Flip use_deterministic_corroboration only after live shadow validation confirms
# no false positives on clean runs and correct flags on fabricated claims.
# See docs/SCORING_IMPROVEMENT_PLAN.md §C3 for rollout criteria.
SHADOW_DETERMINISTIC_CORROBORATION=true
USE_DETERMINISTIC_CORROBORATION=false

# ── NASEMSO call-type rubric (Group F) ───────────────────────────────────────
# shadow mode: always on — composes call-type rubric alongside base checklist
# and persists the diff in checklist_states['shadow_composition'] for inspection.
# Flip USE_CALL_TYPE_RUBRIC only after local active-mode run confirms category
# maxima, missed items, and debrief prose are coherent with the expanded checklist.
# See docs/SCORING_ENGINE_ARCHITECTURE.md §5.5 for denominator change note.
SHADOW_CALL_TYPE_RUBRIC=true
USE_CALL_TYPE_RUBRIC=false


# App settings — set APP_SECRET_KEY to a long random string in production
APP_SECRET_KEY=change_this_to_a_random_string
APP_HOST=0.0.0.0
APP_PORT=8000

# Set to your Cloudflare domain in production
BASE_URL=http://localhost:8000

# CORS allowed origins — JSON array format required by pydantic-settings
# Development default is set in code; override here for staging/production
# ALLOWED_ORIGINS=["https://app.example.com","https://www.example.com"]

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_this_to_a_strong_password
DATABASE_URL=postgresql+asyncpg://ems_user:change_this_to_a_strong_password@postgres:5432/ems_sim

# ── Superuser (auto-created on startup) ───────────────────────────────────────
SUPERUSER_USERNAME=superadmin
SUPERUSER_PASSWORD=change_this_to_a_strong_password

# ── Default agency seed (auto-created on startup if all three are set) ────────
# SEED_AGENCY_NAME:     Display name shown in the UI
# SEED_AGENCY_JOIN_CODE: Code members use to join this agency
# SEED_AGENCY_FILE:     File stem in app/agencies/ (e.g. "seed_agency" → app/agencies/seed_agency.json)
SEED_AGENCY_NAME=My EMS Agency
SEED_AGENCY_JOIN_CODE=change_this_to_a_pin
SEED_AGENCY_FILE=seed_agency

# ── Database connection pool ──────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Logging ───────────────────────────────────────────────────────────────────
# log_format: "json" for production, "console" for local dev
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── AI endpoint rate limits (requests per user per minute) ───────────────────
RATE_LIMIT_CHAT=30
RATE_LIMIT_MED_CONTROL=10
RATE_LIMIT_LEXI=5

# ── Cloud text-to-speech (optional; browser TTS remains the default) ──────────
TTS_PROVIDER=browser
TTS_CACHE_DIR=/tmp/tts_cache

# OpenAI TTS. Set TTS_PROVIDER=openai and provide OPENAI_API_KEY to enable.
# OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TTS_MODEL=tts-1
# Supported: mp3 | opus | wav. mp3 is the safest default for live browser playback.
OPENAI_TTS_FORMAT=mp3
# Speech rate multiplier. 1.0 is normal; 1.1-1.15 keeps EMS dialogue snappy.
OPENAI_TTS_SPEED=1.12

# Google Gemini TTS. Set TTS_PROVIDER=google to use this path.
GEMINI_TTS_MODEL=gemini-2.5-flash-tts
# Local script path. For scripts/test_gemini_tts.py, point this directly at
# your downloaded service-account JSON on your Mac.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
#
# Docker path. The app container cannot see arbitrary Mac paths, so set this
# host path and docker-compose mounts it read-only at /run/secrets/gcp-tts-key.json.
# When enabling TTS in Docker, use:
# GCP_TTS_CREDENTIALS_HOST_PATH=/absolute/path/to/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-tts-key.json

# ── Team Challenge Mode (set to "true" to enable) ────────────────────────────
TEAM_CHALLENGE_ENABLED=true
